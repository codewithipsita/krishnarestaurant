{"id":238,"date":"2025-08-29T05:17:29","date_gmt":"2025-08-28T23:47:29","guid":{"rendered":"https:\/\/lionsclubbls.org\/wp\/?page_id=238"},"modified":"2025-08-31T02:53:00","modified_gmt":"2025-08-30T21:23:00","slug":"our-impacts","status":"publish","type":"page","link":"https:\/\/lionsclubbls.org\/our-impacts\/","title":{"rendered":"Our Impacts"},"content":{"rendered":"        <section class=\"ispl-hero-wrap\" style=\"background: -webkit-linear-gradient(to right, rgba(13,34,64,0.9) 0, rgba(13,34,64,0.1) 100%), url('https:\/\/lionsclubbls.org\/wp-content\/uploads\/2025\/08\/impacts.jpg');background: linear-gradient(to right, rgba(13,34,64,0.9) 0, rgba(13,34,64,0.1) 100%), url('https:\/\/lionsclubbls.org\/wp-content\/uploads\/2025\/08\/impacts.jpg'); \">\r\n            <div class=\"ispl-hero-overlay\" style=\"position:absolute; inset:0; background:rgba(0,0,0,.35);\"><\/div>\r\n            <div class=\"ispl-hero-inner\" style=\"position:relative; max-width:1120px; margin:0 auto; padding:6rem 1.25rem;\">\r\n                                    <h2 style=\"font-size:3rem; line-height:1.1; margin:0 0 1rem;\">Our Impacts \u2013 Changing Lives, Strengthening Communities<\/h2>\r\n                                                    <p style=\"font-size:1.125rem; max-width:800px;\">\u201cThe true measure of our service is not in numbers, but in the lives we touch and the hope we inspire. At the Lions Club of Balasore, every initiative, every project, and every act of kindness leaves behind a lasting impact. From bringing sight to the blind and food to the hungry, to empowering youth, uplifting families, and protecting our environment\u2014we work tirelessly to make a difference where it matters most. Our impacts are more than statistics; they are stories of resilience, compassion, and transformation. Each life touched is a reminder that when we serve together, even the smallest effort can create ripples of change that reach far beyond what we can see. This is our legacy, this is our purpose\u2014building a brighter, stronger, and more compassionate world.\u201d<\/p>\r\n                                                    <p style=\"margin-top:2rem;\">\r\n                        <a href=\"https:\/\/lionsclubbls.org\/our-projects\/\" class=\"ispl-hero-btn\" style=\"display:inline-block; padding:.9rem 1.5rem; background:#ffcc00; color:#111; text-decoration:none; border-radius:.35rem; font-weight:600;\">\r\n                            Our Projects                        <\/a>\r\n                    <\/p>\r\n                            <\/div>\r\n        <\/section>\r\n        \n        <div class=\"ispl-impacts-filter\">\r\n            <select id=\"lionistic_year\">\r\n                <option value=\"\">All Lionistic Years<\/option>\r\n                <option value=\"2023-2024\">2023-2024<\/option><option value=\"2024-2025\">2024-2025<\/option>            <\/select>\r\n\r\n            <select id=\"global_cause\">\r\n                <option value=\"\">All Global Causes<\/option>\r\n                <option value=\"building-the-youth\">Building the Youth<\/option><option value=\"childhood-cancer\">Childhood Cancer<\/option><option value=\"vision\">Vision<\/option>            <\/select>\r\n\r\n            <!--<button id=\"ispl-filter-btn\">Filter<\/button>-->\r\n        <\/div>\r\n\r\n        <div id=\"ispl-impacts-grid\"><\/div>\r\n        <button id=\"ispl-load-more\" data-page=\"1\" style=\"display:none;\">Load More<\/button>\r\n        \n","protected":false},"excerpt":{"rendered":"","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"footnotes":""},"class_list":["post-238","page","type-page","status-publish","hentry"],"_links":{"self":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages\/238","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/lionsclubbls.