{"id":248,"date":"2025-08-29T05:18:28","date_gmt":"2025-08-28T23:48:28","guid":{"rendered":"https:\/\/lionsclubbls.org\/wp\/?page_id=248"},"modified":"2025-08-31T03:01:50","modified_gmt":"2025-08-30T21:31:50","slug":"our-downloads","status":"publish","type":"page","link":"https:\/\/lionsclubbls.org\/our-downloads\/","title":{"rendered":"Downloads"},"content":{"rendered":"        <section class=\"ispl-hero-wrap\" style=\"background: -webkit-linear-gradient(to right, rgba(13,34,64,0.9) 0, rgba(13,34,64,0.1) 100%), url('https:\/\/lionsclubbls.org\/wp-content\/uploads\/2025\/08\/Z5A9865_0-scaled-e1756459382825.jpeg');background: linear-gradient(to right, rgba(13,34,64,0.9) 0, rgba(13,34,64,0.1) 100%), url('https:\/\/lionsclubbls.org\/wp-content\/uploads\/2025\/08\/Z5A9865_0-scaled-e1756459382825.jpeg'); \">\r\n            <div class=\"ispl-hero-overlay\" style=\"position:absolute; inset:0; background:rgba(0,0,0,.35);\"><\/div>\r\n            <div class=\"ispl-hero-inner\" style=\"position:relative; max-width:1120px; margin:0 auto; padding:6rem 1.25rem;\">\r\n                                    <h2 style=\"font-size:3rem; line-height:1.1; margin:0 0 1rem;\">Resources that Empower Service and Society<\/h2>\r\n                                                    <p style=\"font-size:1.125rem; max-width:800px;\">\u201cKnowledge shared is service multiplied. The Downloads section of the Lions Club of Balasore is designed to provide members and the community with valuable resources that inspire action, strengthen service, and spread awareness. From informative brochures and reports to guidelines, forms, and publications, every resource here is a tool for growth, learning, and meaningful impact. These downloads are not just documents\u2014they are pathways to opportunities, ideas to solutions, and support systems that extend our mission beyond meetings and projects. By making knowledge and information accessible, we aim to empower our members, enlighten society, and ensure that together we continue building a future where service is guided by wisdom and strengthened by action.\u201d<\/p>\r\n                                                    <p style=\"margin-top:2rem;\">\r\n                        <a href=\"https:\/\/lionsclubbls.org\/about-us\/\" class=\"ispl-hero-btn\" style=\"display:inline-block; padding:.9rem 1.5rem; background:#ffcc00; color:#111; text-decoration:none; border-radius:.35rem; font-weight:600;\">\r\n                            About Us                        <\/a>\r\n                    <\/p>\r\n                            <\/div>\r\n        <\/section>\r\n        \n<div class=\"events-filters mb-3 text-center\"><button class=\" active\" data-filter=\"all\">All<\/button><\/div>        <div id=\"downloads-table-container\">\r\n            <table class=\"table table-bordered table-striped downloads-table\">\r\n                <thead>\r\n                    <tr>\r\n                        <th>#<\/th>\r\n                        <th>Title<\/th>\r\n                        <th>Publication Date<\/th>\r\n                        <th>Download<\/th>\r\n                    <\/tr>\r\n                <\/thead>\r\n                <tbody><\/tbody>\r\n            <\/table>\r\n            <div>\r\n                <ul class=\"pagination justify-content-center\"><\/ul>\r\n            <\/div>\r\n        <\/div>\r\n\r\n        <script>\r\n        jQuery(document).ready(function($){\r\n            var downloads = [];\r\n\r\n            var perPage = 10, currentPage = 1, currentFilter = 'all';\r\n\r\n            function renderTable(){\r\n                var filtered = downloads.filter(function(d){\r\n                    return currentFilter === 'all' || (d.cats && d.cats.includes(currentFilter));\r\n                });\r\n\r\n                var totalPages = Math.ceil(filtered.length \/ perPage);\r\n                currentPage = Math.min(currentPage, totalPages) || 1;\r\n\r\n                var start = (currentPage - 1) * perPage;\r\n                var rows = filtered.slice(start, start + perPage);\r\n\r\n                var tbody = $('.downloads-table tbody');\r\n                tbody.empty();\r\n                if(rows.length){\r\n                    rows.forEach(function(d, idx){\r\n                        var serial = start + idx + 1;\r\n                        var btn = d.url ? '<a class=\"download\" href=\"'+d.url+'\" target=\"_blank\">Click here<\/a>' : '';\r\n                        tbody.append('<tr><td class=\"text-center\">'+serial+'<\/td><td class=\"text-center\">'+d.title+'<\/td><td class=\"text-center\">'+d.date+'<\/td><td class=\"text-center\">'+btn+'<\/td><\/tr>');\r\n                    });\r\n                } else {\r\n                    tbody.append('<tr><td colspan=\"4\">No downloads found.<\/td><\/tr>');\r\n                }\r\n\r\n                var pag = $('.pagination');\r\n                pag.empty();\r\n                for(var i=1;i<=totalPages;i++){\r\n                    var cls = (i===currentPage)?'page-item active':'page-item';\r\n                    pag.append('<li class=\"'+cls+'\"><a class=\"page-link\" href=\"#\">'+i+'<\/a><\/li>');\r\n                }\r\n            }\r\n\r\n            \/\/ \u2705 Fix filter click\r\n            $(document).on('click','.events-filters button',function(){\r\n                $('.events-filters button').removeClass('btn-primary active').addClass('btn-outline-primary');\r\n                $(this).removeClass('btn-outline-primary').addClass('btn-primary active');\r\n\r\n                currentFilter = $(this).data('filter');\r\n                currentPage = 1;\r\n                renderTable();\r\n            });\r\n\r\n            $(document).on('click','.pagination .page-link',function(e){\r\n                e.preventDefault();\r\n                var page = parseInt($(this).text());\r\n                if(!isNaN(page)){\r\n                    currentPage = page;\r\n                    renderTable();\r\n                }\r\n            });\r\n\r\n            renderTable();\r\n        });\r\n        <\/script>\r\n\r\n        <style>\r\n        .downloads-table td,.downloads-table th { vertical-align: middle; }\r\n       \r\n        <\/style>\r\n        \n","protected":false},"excerpt":{"rendered":"","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"footnotes":""},"class_list":["post-248","page","type-page","status-publish","hentry"],"_links":{"self":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages\/248","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/comments?post=248"}],"version-history":[{"count":6,"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages\/248\/revisions"}],"predecessor-version":[{"id":469,"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages\/248\/revisions\/469"}],"wp:attachment":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/media?parent=248"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}