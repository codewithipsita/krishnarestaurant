{"id":285,"date":"2025-08-29T14:56:49","date_gmt":"2025-08-29T09:26:49","guid":{"rendered":"https:\/\/lionsclubbls.org\/wp\/?page_id=285"},"modified":"2025-08-31T02:51:41","modified_gmt":"2025-08-30T21:21:41","slug":"join-now","status":"publish","type":"page","link":"https:\/\/lionsclubbls.org\/join-now\/","title":{"rendered":"Join Now"},"content":{"rendered":"        <section class=\"ispl-hero-wrap\" style=\"background: -webkit-linear-gradient(to right, rgba(13,34,64,0.9) 0, rgba(13,34,64,0.1) 100%), url('https:\/\/lionsclubbls.org\/wp-content\/uploads\/2025\/08\/387191141_712817950882185_3020544230373617779_n.png');background: linear-gradient(to right, rgba(13,34,64,0.9) 0, rgba(13,34,64,0.1) 100%), url('https:\/\/lionsclubbls.org\/wp-content\/uploads\/2025\/08\/387191141_712817950882185_3020544230373617779_n.png'); \">\r\n            <div class=\"ispl-hero-overlay\" style=\"position:absolute; inset:0; background:rgba(0,0,0,.35);\"><\/div>\r\n            <div class=\"ispl-hero-inner\" style=\"position:relative; max-width:1120px; margin:0 auto; padding:6rem 1.25rem;\">\r\n                                    <h2 style=\"font-size:3rem; line-height:1.1; margin:0 0 1rem;\">Join the Pride \u2013 Serve with Lions Club of Balasore<\/h2>\r\n                                                    <p style=\"font-size:1.125rem; max-width:800px;\">\u201cBecoming a member of the Lions Club of Balasore is not just joining an organization\u2014it is joining a legacy of service, friendship, and purpose. It is a chance to be part of a global family that believes in turning compassion into action and dreams into reality. As a Lion, you lend your time, your voice, and your heart to causes that uplift lives\u2014from feeding the hungry and caring for the sick, to empowering youth and protecting our environment. Membership is more than meetings and badges; it is a journey of leadership, fellowship, and fulfillment. Together, we stand stronger, serve further, and create a world where kindness has no borders. When you join us, you don\u2019t just change others\u2019 lives\u2014you transform your own.\u201d<\/p>\r\n                                                    <p style=\"margin-top:2rem;\">\r\n                        <a href=\"https:\/\/lionsclubbls.org\/five-benefits-of-being-a-lion\/\" class=\"ispl-hero-btn\" style=\"display:inline-block; padding:.9rem 1.5rem; background:#ffcc00; color:#111; text-decoration:none; border-radius:.35rem; font-weight:600;\">\r\n                            Explore the Benefits                        <\/a>\r\n                    <\/p>\r\n                            <\/div>\r\n        <\/section>\r\n        \n","protected":false},"excerpt":{"rendered":"","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"footnotes":""},"class_list":["post-285","page","type-page","status-publish","hentry"],"_links":{"self":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages\/285","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/comments?post=285"}],"version-history":[{"count":3,"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages\/285\/revisions"}],"predecessor-version":[{"id":459,"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/pages\/285\/revisions\/459"}],"wp:attachment":[{"href":"https:\/\/lionsclubbls.org\/wp-json\/wp\/v2\/media?parent=285"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}